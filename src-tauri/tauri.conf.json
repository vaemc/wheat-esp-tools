{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "copyright": "Copyright © 2026 wheat <vaemc520@qq.com>",
    "publisher": "wheat",
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "externalBin": [
      "bin/esptool"
    ],
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "productName": "Wheat ESP Tools",
  "mainBinaryName": "Wheat ESP Tools",
  "version": "1.0.0",
  "identifier": "com.vaemc.wheat.esp.tools",
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "center": true,
        "dragDropEnabled": true,
        "theme": "Dark",
        "height": 900,
        "minHeight": 800,
        "title": "Wheat ESP Tools",
        "width": 1200,
        "minWidth": 950,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": [
          "**"
        ],
        "enable": true
      },
      "csp": null
    }
  }
}